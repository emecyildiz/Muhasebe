@model IEnumerable<Muhasebe.Models.Entities.IslemKategorisi>
@{
    ViewData["Title"] = "İşlem Kategorileri";
    ViewData["PageTitle"] = "İşlem Kategorileri Yönetimi";
    ViewData["PageSubtitle"] = "Masraf ve finans kategorilerini buradan yönetebilirsiniz.";
    ViewData["ShowBack"] = false;
    ViewData["ActionUrl"] = Url.Action("Create");
    ViewData["ActionText"] = "Yeni Kategori";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="card table-responsive border-0 shadow-sm">
        <table class="table mb-0 text-nowrap table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Kategori Adı</th>
                    <th>Tür</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.KategoriId</td>
                            <td><span class="fw-semibold">@item.KategoriAdi</span></td>
                            <td>
                                @if (item.Tur == "Masraf")
                                {
                                    <span class="badge bg-warning-subtle text-warning">Masraf</span>
                                }
                                else if (item.Tur == "Finans")
                                {
                                    <span class="badge bg-primary-subtle text-primary">Finans</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">@item.Tur</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.KategoriId" class="btn btn-sm btn-light" title="Düzenle"><i class="ti ti-edit text-primary"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.KategoriId" class="btn btn-sm btn-light" title="Sil"><i class="ti ti-trash text-danger"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-secondary">Henüz kayıtlı kategori yok.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
