@model Muhasebe.Models.Entities.IslemKategorisi
@{
    ViewData["Title"] = "Kategori Sil";
    ViewData["PageTitle"] = "Kategoriyi Sil";
    ViewData["PageSubtitle"] = "Kategoriyi silmek istediğinize emin misiniz?";
    ViewData["ShowBack"] = true;
    ViewData["BackUrl"] = Url.Action("Index");
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="row">
        <div class="col-lg-8 col-xl-6">
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="ti ti-alert-triangle fs-4 me-2"></i>
                <div>Bu kategoriyi silmek üzeresiniz. Bu işlem geri alınamaz. Eğer bu kategoriye bağlı masraf veya finans kayıtları varsa hata alabilirsiniz.</div>
            </div>
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-secondary fw-normal">Kategori Adı</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.KategoriAdi</dd>
                        
                        <dt class="col-sm-4 text-secondary fw-normal">Kategori Türü</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.Tur</dd>
                    </dl>
                </div>
                <div class="card-footer bg-white p-4 border-0 pt-0">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="KategoriId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger"><i class="ti ti-trash"></i> Evet, Sil</button>
                            <a asp-action="Index" class="btn btn-light">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
