@model IEnumerable<Muhasebe.Models.Entities.Maas>
@{
    ViewData["Title"] = "Maaş Yönetimi";
    ViewData["PageTitle"] = "Maaş Listesi";
    ViewData["PageSubtitle"] = "Kayıtlı maaş bilgileri.";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    @if (User.IsInRole("Mudur") || User.IsInRole("Admin"))
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-primary text-white">
                    <div class="card-body">
                        <h6 class="card-title text-white-50">Toplam Maaş Bütçesi</h6>
                        <h3 class="mb-0">@((ViewBag.ToplamMaasButcesi ?? 0).ToString("N2")) ₺</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-info text-white">
                    <div class="card-body">
                        <h6 class="card-title text-white-50">Dağıtılan Maaşlar</h6>
                        <h3 class="mb-0">@((ViewBag.KullanilanMaas ?? 0).ToString("N2")) ₺</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm @((ViewBag.KalanMaas ?? 0) < 0 ? "bg-danger" : "bg-success") text-white">
                    <div class="card-body">
                        <h6 class="card-title text-white-50">Kalan Maaş Limiti</h6>
                        <h3 class="mb-0">@((ViewBag.KalanMaas ?? 0).ToString("N2")) ₺</h3>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (User.IsInRole("Admin") || User.IsInRole("Mudur"))
    {
        <div class="d-flex mb-3">
            <a asp-action="Create" class="btn btn-primary"><i class="ti ti-plus"></i> Yeni Maaş Ekle</a>
        </div>
    }

    <div class="card border-0 shadow-sm table-responsive">
        <table class="table mb-0 text-nowrap align-middle table-hover">
            <thead class="table-light">
                <tr>
                    <th>Personel</th>
                    <th>Aylık Tutar</th>
                    <th>Başlangıç Tarihi</th>
                    <th>Bitiş Tarihi</th>
                    @if (User.IsInRole("Admin") || User.IsInRole("Mudur"))
                    {
                        <th>İşlemler</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Kullanici?.Ad + " " + item.Kullanici?.Soyad)</td>
                        <td class="fw-semibold text-primary">@item.AylikTutar.ToString("N2") ₺</td>
                        <td>@item.BaslangicTarihi.ToString("dd.MM.yyyy")</td>
                        <td>@(item.BitisTarihi.HasValue ? item.BitisTarihi.Value.ToString("dd.MM.yyyy") : "—")</td>
                        @if (User.IsInRole("Admin") || User.IsInRole("Mudur"))
                        {
                            <td>
                                @if (item.KullaniciId == ViewBag.AktifKullaniciId && User.IsInRole("Mudur"))
                                {
                                    <span class="text-muted fst-italic small">Yetki dışı (Kendi Maaşınız)</span>
                                }
                                else
                                {
                                    <a asp-action="Edit" asp-route-id="@item.MaasId" class="btn btn-sm btn-outline-primary"><i class="ti ti-edit"></i> Düzenle</a>
                                    <a asp-action="Delete" asp-route-id="@item.MaasId" class="btn btn-sm btn-outline-danger"><i class="ti ti-trash"></i> Sil</a>
                                }
                            </td>
                        }
                    </tr>
                }
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-secondary">Listelenecek maaş kaydı bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
