@model Muhasebe.Models.Entities.Maas
@{
    ViewData["Title"] = "Yeni Maaş Ekle";
    ViewData["PageTitle"] = "Yeni Maaş";
    ViewData["PageSubtitle"] = "Sisteme yeni bir personel maaşı tanımlayın.";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="card border-0 shadow-sm col-md-8 col-lg-6 mx-auto">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="KullaniciId" class="form-label">Personel</label>
                    <select asp-for="KullaniciId" class="form-select" asp-items="ViewBag.KullaniciId" required>
                        <option value="">-- Personel Seçin --</option>
                    </select>
                    <span asp-validation-for="KullaniciId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AylikTutar" class="form-label">Aylık Tutar (₺)</label>
                    <input asp-for="AylikTutar" type="number" step="0.01" class="form-control" required />
                    <span asp-validation-for="AylikTutar" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="BaslangicTarihi" class="form-label">Başlangıç Tarihi</label>
                    <input asp-for="BaslangicTarihi" type="date" class="form-control" required />
                    <span asp-validation-for="BaslangicTarihi" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="BitisTarihi" class="form-label">Bitiş Tarihi (Opsiyonel)</label>
                    <input asp-for="BitisTarihi" type="date" class="form-control" />
                    <span asp-validation-for="BitisTarihi" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-check"></i> Kaydet</button>
                    <a asp-action="Index" class="btn btn-light">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
