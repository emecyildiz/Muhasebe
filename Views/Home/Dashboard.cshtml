@model Muhasebe.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Panel";
}
<div class="container-fluid">
    <div class="row ">
        <div class="col-12">
            <div class="mb-6">
                <h1 class="fs-3 mb-1">Panel</h1>
                <p class="text-secondary mb-0">Genel finansal özet ve metrikleriniz.</p>
            </div>
        </div>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-2">
                <div class="d-flex gap-3 ">
                    <div class="icon-shape icon-md bg-primary text-white rounded-2">
                        <i class="ti ti-report-analytics fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Toplam Gelir</h2>
                        <h3 class="fw-bold mb-0">@Model.ToplamGelir.ToString("C")</h3>
                        <p class="text-primary mb-0 small">Ana bütçe + Ek gelirler</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-2">
                <div class="d-flex gap-3 ">
                    <div class="icon-shape icon-md bg-success text-white rounded-2">
                        <i class="ti ti-repeat fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Toplam Gider</h2>
                        <h3 class="fw-bold mb-0">@Model.ToplamGider.ToString("C")</h3>
                        <p class="text-success mb-0 small">Tüm Giderler (Maaş, Masraf, vb.)</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-info bg-opacity-10 border border-info border-opacity-25 rounded-2">
                <div class="d-flex gap-3 ">
                    <div class="icon-shape icon-md bg-info text-white rounded-2">
                        <i class="ti ti-currency-dollar fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Maaş Yükü</h2>
                        <h3 class="fw-bold mb-0">@Model.ToplamMaasYuku.ToString("C")</h3>
                        <p class="text-info mb-0 small">Aylık maaş toplamı</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-2">
                <div class="d-flex gap-3 ">
                    <div class="icon-shape icon-md bg-warning text-white rounded-2">
                        <i class="ti ti-notes fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Bekleyen Masraf</h2>
                        <h3 class="fw-bold mb-0">@Model.BekleyenMasrafTalebi.ToString("C")</h3>
                        <p class="text-warning mb-0 small">Onay bekleyen talepler</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.ButceDetaylari != null && Model.ButceDetaylari.Any())
    {
        <div class="row mb-3 mt-2">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h4 class="h5 mb-0 text-secondary">Ayrılan Bütçe Dağılımı</h4>
                    <span class="badge bg-primary fs-6">Ana Bütçe: @Model.ToplamAktifButce.ToString("N2") ₺</span>
                </div>
            </div>
        </div>
        <div class="row g-3 mb-4">
            @foreach (var detay in Model.ButceDetaylari)
            {
                <div class="col-md-4 col-lg-3">
                    <a href="@(detay.KategoriAdi == "Maaş Bütçesi" ? Url.Action("Index", "Maas") : "#")" class="text-decoration-none">
                        <div class="card p-3 shadow-sm border-0 bg-light h-100 transition-hover" style="border-left: 4px solid #0d6efd !important;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 text-dark fw-bold">@detay.KategoriAdi</h6>
                                <i class="ti @(detay.KategoriAdi == "Maaş Bütçesi" ? "ti-users" : "ti-wallet") text-muted"></i>
                            </div>
                            <h4 class="text-primary mb-0">@detay.AyrilanTutar.ToString("N2") ₺</h4>
                            <small class="text-muted d-block mt-1">Tanımlı Limit</small>
                        </div>
                    </a>
                </div>
            }
        </div>
    }

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white px-4 py-3 border-bottom">
                    <h4 class="mb-0 h5 text-dark fw-bold">Son Finansal Hareketler</h4>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">İşlem Türü</th>
                                <th>Açıklama</th>
                                <th>Tarih</th>
                                <th>Tutar</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Model.SonIslemler != null && Model.SonIslemler.Any())
                            {
                                foreach(var islem in Model.SonIslemler)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <span class="fw-semibold text-secondary">@islem.IslemTuru</span>
                                        </td>
                                        <td>@islem.Aciklama</td>
                                        <td>@islem.Tarih.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>
                                            <span class="fw-bold text-@islem.CSSRenk">@islem.Tutar.ToString("N2") ₺</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-@islem.CSSRenk bg-opacity-10 text-@islem.CSSRenk px-2 py-1">@islem.Durum</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        Henüz kaydedilmiş finansal bir işlem veya masraf talebi bulunmuyor.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-12">
            <footer class="text-center py-2 text-secondary small">
                <p class="mb-0">Arayüz şablonu — Muhasebe okul projesi</p>
            </footer>
        </div>
    </div>
</div>
