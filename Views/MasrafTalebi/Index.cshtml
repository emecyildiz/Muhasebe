@model IEnumerable<Muhasebe.Models.Entities.MasrafTalebi>
@{
    ViewData["Title"] = "Masraf Talepleri";
    ViewData["PageTitle"] = "Masraf Talepleri";
    ViewData["PageSubtitle"] = "Oluşturulan masraf taleplerini görüntüleyin ve yönetin.";
    ViewData["ShowBack"] = false;
    ViewData["ActionUrl"] = Url.Action("Create");
    ViewData["ActionText"] = "Yeni Talep";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="card table-responsive border-0 shadow-sm">
        <table class="table mb-0 text-nowrap table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Talep Eden</th>
                    <th>Departman</th>
                    <th>Kategori</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th class="text-end">Tutar</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TalepId</td>
                            <td>
                                <span class="fw-semibold">@item.TalepEdenKullanici?.Ad @item.TalepEdenKullanici?.Soyad</span>
                            </td>
                            <td>@(item.Departman?.DepartmanAdi ?? "—")</td>
                            <td>@(item.Kategori?.KategoriAdi ?? "—")</td>
                            <td>@item.TalepTarihi.ToString("dd.MM.yyyy")</td>
                            <td>@await Html.PartialAsync("_DurumBadge", item.Durum)</td>
                            <td class="text-end fw-semibold">@item.Tutar.ToString("N2") ₺</td>
                            <td class="text-end">
                                <a asp-action="Detail" asp-route-id="@item.TalepId" class="btn btn-sm btn-light" title="Detay">
                                    <i class="ti ti-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-secondary">
                            Henüz masraf talebi yok. <a asp-action="Create">İlk talebi oluştur</a>.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
