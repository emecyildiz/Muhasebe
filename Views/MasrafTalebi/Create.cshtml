@model Muhasebe.ViewModels.MasrafTalebiCreateViewModel
@{
    ViewData["Title"] = "Yeni Masraf Talebi";
    ViewData["PageTitle"] = "Yeni Masraf Talebi";
    ViewData["PageSubtitle"] = "Masraf talebinizi oluşturun; onay sürecine gönderilecektir.";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="row">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="KategoriId" class="form-label">Masraf Kategorisi</label>
                                <select asp-for="KategoriId" class="form-select" asp-items="ViewBag.Kategoriler">
                                    <option value="">— Kategori seçiniz —</option>
                                </select>
                                <span asp-validation-for="KategoriId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Tutar" class="form-label">Tutar</label>
                                <div class="input-group">
                                    <input asp-for="Tutar" type="number" step="0.01" min="0.01" class="form-control" placeholder="0,00" />
                                    <span class="input-group-text">₺</span>
                                </div>
                                <span asp-validation-for="Tutar" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Aciklama" class="form-label">Açıklama</label>
                                <textarea asp-for="Aciklama" class="form-control" rows="4" placeholder="Masrafın amacı ve detayları"></textarea>
                                <span asp-validation-for="Aciklama" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="alert alert-info small mt-4 mb-0">
                            <i class="ti ti-info-circle me-1"></i>
                            Talep oluşturulduğunda durum <strong>Bekliyor</strong> olarak kaydedilir. (Aktif kullanıcı bilgisi auth bağlanınca otomatik gelecek.)
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Talebi Gönder</button>
                            <a asp-action="Index" class="btn btn-light">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
