@model Muhasebe.Models.Entities.Departman
@{
    ViewData["Title"] = "Departman Detayı";
    ViewData["PageTitle"] = Model.DepartmanAdi;
    ViewData["PageSubtitle"] = "Departman detayları ve bağlı personel listesi.";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4">
                <span class="text-secondary small">Müdür</span>
                <p class="fw-semibold mb-0">@(Model.Mudur != null ? $"{Model.Mudur.Ad} {Model.Mudur.Soyad}" : "Atanmadı")</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4">
                <span class="text-secondary small">Personel Sayısı</span>
                <p class="fw-semibold mb-0">@(Model.Kullanicis?.Count ?? 0)</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4">
                <span class="text-secondary small">Oluşturulma</span>
                <p class="fw-semibold mb-0">@(Model.OlusturulmaTarihi?.ToString("dd.MM.yyyy HH:mm") ?? "—")</p>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm table-responsive">
        <div class="card-header bg-white px-4 py-3">
            <h2 class="h6 mb-0">Departman Personeli</h2>
        </div>
        <table class="table mb-0 table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Rol</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Kullanicis != null && Model.Kullanicis.Any())
                {
                    foreach (var k in Model.Kullanicis)
                    {
                        <tr>
                            <td>@k.Ad @k.Soyad</td>
                            <td>@k.Eposta</td>
                            <td>@(k.Rol?.RolAdi ?? "—")</td>
                            <td>
                                @if (k.Durum == true)
                                {
                                    <span class="badge bg-success-subtle text-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">Pasif</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-secondary">Bu departmanda kayıtlı personel yok.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <a asp-controller="DepartmanButce" asp-action="Detail" asp-route-id="@Model.DepartmanId" class="btn btn-outline-primary btn-sm">
            <i class="ti ti-chart-pie"></i> Bütçe Geçmişi
        </a>
    </div>
</div>
