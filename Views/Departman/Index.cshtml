@model IEnumerable<Muhasebe.Models.Entities.Departman>
@{
    ViewData["Title"] = "Departmanlar";
    ViewData["PageTitle"] = "Departman Yönetimi";
    ViewData["PageSubtitle"] = "Sistemdeki tüm departmanları buradan yönetebilirsiniz.";
    ViewData["ShowBack"] = false;
    ViewData["ActionUrl"] = Url.Action("Create");
    ViewData["ActionText"] = "Yeni Departman";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="card table-responsive border-0 shadow-sm">
        <table class="table mb-0 text-nowrap table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Departman Adı</th>
                    <th>Müdür</th>
                    <th>Oluşturulma</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DepartmanId</td>
                            <td><span class="fw-semibold">@item.DepartmanAdi</span></td>
                            <td>@(item.Mudur != null ? $"{item.Mudur.Ad} {item.Mudur.Soyad}" : (item.MudurId.HasValue ? $"ID: {item.MudurId}" : "Atanmadı"))</td>
                            <td>@(item.OlusturulmaTarihi?.ToString("dd.MM.yyyy") ?? "—")</td>
                            <td class="text-end">
                                <a asp-action="Detail" asp-route-id="@item.DepartmanId" class="btn btn-sm btn-light" title="Detay"><i class="ti ti-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.DepartmanId" class="btn btn-sm btn-light" title="Düzenle"><i class="ti ti-edit text-primary"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.DepartmanId" class="btn btn-sm btn-light" title="Sil"><i class="ti ti-trash text-danger"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-secondary">Henüz kayıtlı departman yok.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
