@{
}
@model Muhasebe.Models.Entities.Departman

@{
    ViewData["Title"] = "Yeni Departman Ekle";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h1 class="fs-3 mb-1">Yeni Departman Oluştur</h1>
        <p class="mb-0">Sisteme dahil edilecek yeni departman bilgilerini giriniz.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">Departman Listesine Dön</a>
    </div>
</div>

<div class="card">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @* Form genelindeki doğrulama hatalarını gösterir *@
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DepartmanAdi" class="form-label">Departman Adı</label>
                    <input asp-for="DepartmanAdi" class="form-control" placeholder="Örn: Bilgi İşlem" required />
                    <span asp-validation-for="DepartmanAdi" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="MudurId" class="form-label">Müdür (Yönetici ID)</label>
                    <input asp-for="MudurId" type="number" class="form-control" placeholder="Örn: 101 (Opsiyonel)" />
                    <span asp-validation-for="MudurId" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Departmanı Kaydet</button>
                <button type="reset" class="btn btn-light">Formu Temizle</button>
            </div>
        </form>
    </div>
</div>