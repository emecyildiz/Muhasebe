@model Muhasebe.Models.Entities.Departman
@{
    ViewData["Title"] = "Departman Düzenle";
    ViewData["PageTitle"] = "Departman Düzenle";
    ViewData["PageSubtitle"] = Model.DepartmanAdi;
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="row">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Edit" asp-route-id="@Model.DepartmanId" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="DepartmanId" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="DepartmanAdi" class="form-label"></label>
                                <input asp-for="DepartmanAdi" class="form-control" />
                                <span asp-validation-for="DepartmanAdi" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MudurId" class="form-label">Müdür</label>
                                <select asp-for="MudurId" class="form-select user-select2" data-placeholder="Müdür seçin (Opsiyonel)">
                                    @if (Model.MudurId.HasValue && Model.Mudur != null)
                                    {
                                        <option value="@Model.MudurId" selected>@Model.Mudur.Ad @Model.Mudur.Soyad</option>
                                    }
                                </select>
                                <span asp-validation-for="MudurId" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Güncelle</button>
                            <a asp-action="Index" class="btn btn-light">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.user-select2').select2({
                theme: 'bootstrap-5',
                placeholder: $(this).data('placeholder'),
                allowClear: true,
                ajax: {
                    url: '@Url.Action("KullaniciAra", "Kullanici")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            q: params.term
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data
                        };
                    },
                    cache: true
                }
            });
        });
    </script>
}
