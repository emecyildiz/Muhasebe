@{
}
@model Muhasebe.Models.Entities.Departman

@{
    ViewData["Title"] = "Departman Düzenle";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div>
                <h1 class="fs-3 mb-1">Departmanı Düzenle</h1>
                <p class="mb-0">Mevcut departman bilgilerini güncelliyorsunuz.</p>
            </div>
            <div>
                <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    @* KRİTİK NOKTA: Güncelleme işlemi için ID numarasını gizli olarak gönderiyoruz *@
                    <input type="hidden" asp-for="DepartmanId" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DepartmanAdi" class="form-label">Departman Adı</label>
                            <input asp-for="DepartmanAdi" class="form-control" required>
                            <span asp-validation-for="DepartmanAdi" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="MudurId" class="form-label">Müdür (Yönetici ID)</label>
                            <input asp-for="MudurId" type="number" class="form-control">
                            <span asp-validation-for="MudurId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
                        <a asp-action="Index" class="btn btn-light">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>