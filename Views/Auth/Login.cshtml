@model LoginViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Giriş Yap";
}
<div class="container d-flex align-items-center justify-content-center min-vh-100 py-4">
    <div class="card shadow-sm border-0" style="max-width:420px; width:100%;">
        <div class="card-body p-5">
            <div class="text-center mb-3">
                <a asp-controller="Home" asp-action="Index" class="mb-4 d-inline-flex align-items-center justify-content-center text-decoration-none">
                    <img src="~/images/logo.svg" alt="Muhasebe" height="36" asp-append-version="true" />
                </a>
                <h1 class="card-title mb-0 h5">Hesabınıza giriş yapın</h1>
                <p class="small text-muted mt-2 mb-0">Bilgilerinizi girerek sisteme erişebilirsiniz.</p>
            </div>

            <form class="needs-validation mt-3" method="post" asp-controller="Auth" asp-action="Login">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger p-2 small">
                        <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Eposta" class="form-label">E-posta</label>
                    <input asp-for="Eposta" type="email" class="form-control" placeholder="ornek@kurum.edu.tr" required autofocus autocomplete="username" />
                    <span asp-validation-for="Eposta" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Sifre" class="form-label d-flex justify-content-between">
                        <span>Şifre</span>
                    </label>
                    <input asp-for="Sifre" type="password" class="form-control" placeholder="Şifre" required autocomplete="current-password" />
                    <span asp-validation-for="Sifre" class="text-danger small"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input id="remember" name="remember" class="form-check-input" type="checkbox" value="true" />
                        <label class="form-check-label small" for="remember">Beni hatırla</label>
                    </div>
                </div>
                <button class="btn btn-primary w-100" type="submit">Giriş Yap</button>
            </form>

        </div>
    </div>
</div>
