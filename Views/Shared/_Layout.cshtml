<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Muhasebe</title>
    <meta name="theme-color" content="#ffffff" />
    <link rel="manifest" href="~/site.webmanifest" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/favicon-16x16.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32x32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" crossorigin />
    <link rel="stylesheet" href="~/Muhasebe.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var act = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavClass(string c, string a) => (string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) && string.Equals(act, a, StringComparison.OrdinalIgnoreCase)) ? "nav-link active" : "nav-link";
    string NavCtrlClass(string c) => string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
    var rolePreview = Context?.Request?.Query["role"].ToString();
    var roleFromClaim = User?.Claims?.FirstOrDefault(c => c.Type == "RolAdi")?.Value;
    var currentRole = !string.IsNullOrWhiteSpace(rolePreview)
        ? rolePreview
        : (!string.IsNullOrWhiteSpace(roleFromClaim) ? roleFromClaim : "Personel");
    var roleNormalized = currentRole.Trim().ToLowerInvariant();
    var isAdmin = roleNormalized.Contains("admin");
    var isManager = roleNormalized.Contains("mudur") || roleNormalized.Contains("yönetici") || roleNormalized.Contains("yonetici");
    var isFinance = roleNormalized.Contains("finans") || roleNormalized.Contains("muhasebe");
    var canSeeFinance = isAdmin || isFinance;
    var canSeeApprovals = isAdmin || isManager;
    var canSeeDepartment = isAdmin || isManager;
}
  <div id="overlay" class="overlay"></div>
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <button id="toggleBtn" type="button" class="d-none d-lg-inline-flex btn btn-light btn-icon btn-sm ">
      <i class="ti ti-layout-sidebar-left-expand"></i>
    </button>
    <button id="mobileBtn" type="button" class="btn btn-light btn-icon btn-sm d-lg-none me-2">
      <i class="ti ti-layout-sidebar-left-expand"></i>
    </button>
    <div>
      <ul class="list-unstyled d-flex align-items-center mb-0 gap-1">
        <li>
          <a class="position-relative btn-icon btn-sm btn-light btn rounded-circle" data-bs-toggle="dropdown"
            aria-expanded="false" href="#" role="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-bell">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M10 5a2 2 0 1 1 4 0a7 7 0 0 1 4 6v3a4 4 0 0 0 2 3h-16a4 4 0 0 0 2 -3v-3a7 7 0 0 1 4 -6" />
              <path d="M9 17v1a3 3 0 0 0 6 0v-1" />
            </svg>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger mt-2 ms-n2">2<span class="visually-hidden">bildirim</span></span>
          </a>
          <div class="dropdown-menu dropdown-menu-end dropdown-menu-md p-0">
            <ul class="list-unstyled p-0 m-0">
              <li class="px-4 py-3 text-center text-muted small">Henüz gerçek bildirim yok — backend ile bağlanır.</li>
            </ul>
          </div>
        </li>
        <li class="ms-3 dropdown">
          <a href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="~/images/placeholder-avatar-sm.png" alt="" class="avatar avatar-sm rounded-circle" width="32" height="32" asp-append-version="true" />
          </a>
          <div class="dropdown-menu dropdown-menu-end p-0" style="min-width: 200px;">
            <div class="d-flex gap-3 align-items-center border-dashed border-bottom px-3 py-3">
              <img src="~/images/placeholder-avatar-md.png" alt="" class="avatar avatar-md rounded-circle" width="48" height="48" asp-append-version="true" />
              <div>
                <h4 class="mb-0 small">Kullanıcı</h4>
                <p class="mb-0 small text-muted">Rol: @currentRole</p>
              </div>
            </div>
            <div class="p-3 d-flex flex-column gap-1 small lh-lg">
              <a asp-controller="Auth" asp-action="Login" class="text-decoration-none"><span>Giriş sayfası</span></a>
            </div>
          </div>
        </li>
      </ul>
    </div>
  </nav>

  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
      <a asp-controller="Home" asp-action="Dashboard" class="d-inline-flex align-items-center text-decoration-none">
        <img src="~/images/logo.svg" alt="Muhasebe" height="28" asp-append-version="true" />
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Uygulama</small></li>
      <li>
        <a class="@NavClass("Home","Dashboard")" asp-controller="Home" asp-action="Dashboard"><i class="ti ti-home"></i><span class="nav-text">Panel</span></a>
      </li>
      <li>
        <a class="@NavClass("Masraf","Taleplerim")" asp-controller="Masraf" asp-action="Taleplerim"><i class="ti ti-wallet"></i><span class="nav-text">Masraf Talepleri</span></a>
      </li>
      @if (canSeeFinance)
      {
          <li>
            <a class="@NavClass("Finans","AnaKasa")" asp-controller="Finans" asp-action="AnaKasa"><i class="ti ti-building-bank"></i><span class="nav-text">Ana Kasa</span></a>
          </li>
      }
      @if (canSeeApprovals)
      {
          <li class="px-4 pt-4 pb-2"><small class="nav-text">Onay</small></li>
          <li>
            <a class="@NavClass("Onay","BekleyenTalepler")" asp-controller="Onay" asp-action="BekleyenTalepler"><i class="ti ti-checkbox"></i><span class="nav-text">Onay Bekleyenler</span></a>
          </li>
      }
      @if (canSeeDepartment)
      {
          <li class="px-4 pt-4 pb-2"><small class="nav-text">İnsan Kaynakları</small></li>
          <li>
            <a class="@NavCtrlClass("Kullanici")" asp-controller="Kullanici" asp-action="Index"><i class="ti ti-users"></i><span class="nav-text">Kullanıcılar</span></a>
          </li>
      }
      @if (isAdmin)
      {
          <li class="px-4 pt-4 pb-2"><small class="nav-text">Yönetim</small></li>
          <li>
            <a class="@NavCtrlClass("Departman")" asp-controller="Departman" asp-action="Index"><i class="ti ti-building"></i><span class="nav-text">Departmanlar</span></a>
          </li>
          <li>
            <a class="@NavCtrlClass("DepartmanButce")" asp-controller="DepartmanButce" asp-action="Index"><i class="ti ti-chart-pie"></i><span class="nav-text">Departman Bütçeleri</span></a>
          </li>
          <li>
            <a class="@NavClass("Admin","Index")" asp-controller="Admin" asp-action="Index"><i class="ti ti-settings"></i><span class="nav-text">Sistem Ayarları</span></a>
          </li>
      }
      <li class="px-4 pt-4 pb-2"><small class="nav-text">Hesap</small></li>
      <li>
        <a class="nav-link" asp-controller="Auth" asp-action="Login"><i class="ti ti-login"></i><span class="nav-text">Çıkış</span></a>
      </li>
      <li>
        <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="ti ti-home"></i><span class="nav-text">Giriş Öncesi Sayfa</span></a>
      </li>
    </ul>
  </aside>

  <main id="content" class="content py-10">
    @RenderBody()
  </main>

  <script type="module" src="~/js/main.js" asp-append-version="true" crossorigin></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
