<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Muhasebe</title>
    <meta name="theme-color" content="#ffffff" />
    <link rel="manifest" href="~/site.webmanifest" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/favicon-16x16.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32x32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" crossorigin />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Muhasebe.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var act = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavClass(string c, string a) => (string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) && string.Equals(act, a, StringComparison.OrdinalIgnoreCase)) ? "nav-link active" : "nav-link";
    string NavCtrlClass(string c) => string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
    var rolePreview = Context?.Request?.Query["role"].ToString();
    var roleFromClaim = User?.Claims?.FirstOrDefault(c => c.Type == "RolAdi")?.Value;
    var currentRole = !string.IsNullOrWhiteSpace(rolePreview)
        ? rolePreview
        : (!string.IsNullOrWhiteSpace(roleFromClaim) ? roleFromClaim : "Admin");
    var roleNormalized = currentRole.Trim().ToLowerInvariant();
    var isAdmin = roleNormalized.Contains("admin");
    var isManager = roleNormalized.Contains("mudur") || roleNormalized.Contains("yönetici") || roleNormalized.Contains("yonetici");
    var isFinance = roleNormalized.Contains("finans") || roleNormalized.Contains("muhasebe");
    var canSeeFinance = isAdmin || isFinance;
    var canSeeApprovals = isAdmin || isManager;
    var canSeeDepartment = isAdmin || isManager;
}
  <div id="overlay" class="overlay" onclick="closeMobileSidebar(event)"></div>
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <button id="toggleBtn" type="button" class="d-none d-lg-inline-flex btn btn-light btn-icon btn-sm" onclick="toggleSidebar(event)">
      <i class="ti ti-layout-sidebar-left-expand"></i>
    </button>
    <button id="mobileBtn" type="button" class="btn btn-light btn-icon btn-sm d-lg-none me-2" onclick="toggleMobileSidebar(event)">
      <i class="ti ti-layout-sidebar-left-expand"></i>
    </button>
    <div>
      <ul class="list-unstyled d-flex align-items-center mb-0 gap-1">
        <li class="dropdown">
          @await Component.InvokeAsync("Bildirimler")
        </li>
        <li class="ms-3 dropdown">
          <a href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="~/images/placeholder-avatar-sm.png" alt="" class="avatar avatar-sm rounded-circle" width="32" height="32" asp-append-version="true" />
          </a>
          <div class="dropdown-menu dropdown-menu-end p-0" style="min-width: 200px;">
            <div class="d-flex gap-3 align-items-center border-dashed border-bottom px-3 py-3">
              <img src="~/images/placeholder-avatar-md.png" alt="" class="avatar avatar-md rounded-circle" width="48" height="48" asp-append-version="true" />
              <div>
                <h4 class="mb-0 small">@(User.Identity != null && User.Identity.IsAuthenticated ? User.Identity.Name : "Misafir")</h4>
                <p class="mb-0 small text-muted">Rol: @currentRole</p>
              </div>
            </div>
            <div class="p-3 d-flex flex-column gap-1 small lh-lg">
              <a asp-controller="Auth" asp-action="Logout" class="text-decoration-none text-danger"><span>Çıkış Yap</span></a>
            </div>
          </div>
        </li>
      </ul>
    </div>
  </nav>

  <aside id="sidebar" class="sidebar">
    @await Component.InvokeAsync("SidebarMenu")
  </aside>

  <main id="content" class="content py-10">
    @RenderBody()
  </main>

  <script type="module" src="~/js/main.js" asp-append-version="true" crossorigin="anonymous"></script>
  
  <!-- JavaScript sidebar toggle entegrasyonu -->
  <script>
    function toggleSidebar(e) {
        if(e) e.preventDefault();
        var sidebar = document.getElementById('sidebar');
        var topbar = document.getElementById('topbar');
        var content = document.getElementById('content');
        if(sidebar) sidebar.classList.toggle('collapsed');
        if(topbar) topbar.classList.toggle('full');
        if(content) content.classList.toggle('full');
    }

    function toggleMobileSidebar(e) {
        if(e) e.preventDefault();
        var sidebar = document.getElementById('sidebar');
        var overlay = document.getElementById('overlay');
        if(sidebar) sidebar.classList.toggle('mobile-show');
        if(overlay) overlay.classList.toggle('show');
    }

    function closeMobileSidebar(e) {
        if(e) e.preventDefault();
        var sidebar = document.getElementById('sidebar');
        var overlay = document.getElementById('overlay');
        if(sidebar) sidebar.classList.remove('mobile-show');
        if(overlay) overlay.classList.remove('show');
    }
  </script>

  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
