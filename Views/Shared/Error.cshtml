@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}
<div class="container-fluid pb-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body p-5">
                    <div class="icon-shape icon-lg bg-danger bg-opacity-10 text-danger rounded-circle mx-auto mb-4">
                        <i class="ti ti-alert-circle fs-2"></i>
                    </div>
                    <h1 class="h4 mb-2">Beklenmeyen bir hata oluştu</h1>
                    <p class="text-secondary mb-4">İşleminiz tamamlanamadı. Lütfen tekrar deneyin veya panele dönün.</p>
                    @if (Model.ShowRequestId)
                    {
                        <p class="small text-muted mb-4">İstek kodu: <code>@Model.RequestId</code></p>
                    }
                    <a asp-controller="Home" asp-action="Dashboard" class="btn btn-primary">Panele dön</a>
                </div>
            </div>
        </div>
    </div>
</div>
