@model Muhasebe.Models.NotFoundViewModel
@{
    ViewData["Title"] = "Kayıt Bulunamadı";
    var listLabel = Model.ListLabel ?? $"{Model.EntityName} listesine dön";
}
<div class="container-fluid pb-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body p-5">
                    <div class="icon-shape icon-lg bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-4">
                        <i class="ti ti-file-search fs-2"></i>
                    </div>
                    <h1 class="h4 mb-2">@Model.EntityName bulunamadı</h1>
                    <p class="text-secondary mb-4">
                        @(Model.Message ?? $"Aradığınız {Model.EntityName.ToLower()} kaydı sistemde mevcut değil veya silinmiş olabilir.")
                        @if (Model.RequestedId.HasValue)
                        {
                            <span class="d-block mt-2 small">İstenen kayıt no: <strong>#@Model.RequestedId</strong></span>
                        }
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        <a asp-controller="@Model.ListController" asp-action="@Model.ListAction" class="btn btn-primary">
                            <i class="ti ti-arrow-left"></i> @listLabel
                        </a>
                        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-secondary">
                            <i class="ti ti-home"></i> Panele dön
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
