@{
    var title = ViewData["PageTitle"] ?? ViewData["Title"];
    var subtitle = ViewData["PageSubtitle"] as string;
    var backAction = ViewData["BackAction"] as string ?? "Index";
    var backController = ViewData["BackController"] as string ?? ViewContext.RouteData.Values["controller"]?.ToString();
    var showBack = ViewData["ShowBack"] as bool? ?? true;
    var actionUrl = ViewData["ActionUrl"] as string;
    var actionText = ViewData["ActionText"] as string;
    var actionIcon = ViewData["ActionIcon"] as string ?? "ti-plus";
}
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <h1 class="fs-3 mb-1">@title</h1>
                @if (!string.IsNullOrWhiteSpace(subtitle))
                {
                    <p class="text-secondary mb-0">@subtitle</p>
                }
            </div>
            <div class="d-flex flex-wrap gap-2">
                @if (showBack)
                {
                    <a asp-controller="@backController" asp-action="@backAction" class="btn btn-outline-secondary btn-sm">
                        <i class="ti ti-arrow-left"></i> Geri
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(actionUrl) && !string.IsNullOrWhiteSpace(actionText))
                {
                    <a href="@actionUrl" class="btn btn-primary btn-sm">
                        <i class="ti @actionIcon"></i> @actionText
                    </a>
                }
            </div>
        </div>
    </div>
</div>
