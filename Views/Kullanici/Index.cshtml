@model IEnumerable<Muhasebe.Models.Entities.Kullanici>
@{
    ViewData["Title"] = "Kullanıcılar";
    ViewData["PageTitle"] = "Kullanıcı Yönetimi";
    ViewData["PageSubtitle"] = "Sistemdeki tüm kullanıcıları buradan yönetebilirsiniz.";
    ViewData["ShowBack"] = false;
    if (User.IsInRole("Admin"))
    {
        ViewData["ActionUrl"] = Url.Action("Create");
        ViewData["ActionText"] = "Yeni Kullanıcı";
    }
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="card table-responsive border-0 shadow-sm">
        <table class="table mb-0 text-nowrap table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Departman</th>
                    <th>Rol</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.KullaniciId</td>
                            <td><span class="fw-semibold">@item.Ad @item.Soyad</span></td>
                            <td>@item.Eposta</td>
                            <td>@(item.Departman?.DepartmanAdi ?? "—")</td>
                            <td>@(item.Rol?.RolAdi ?? "—")</td>
                            <td>
                                @if (item.Durum == true)
                                {
                                    <span class="badge bg-success-subtle text-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">Pasif</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Detail" asp-route-id="@item.KullaniciId" class="btn btn-sm btn-light" title="Detay"><i class="ti ti-eye"></i></a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.KullaniciId" class="btn btn-sm btn-light" title="Düzenle"><i class="ti ti-edit text-primary"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.KullaniciId" class="btn btn-sm btn-light" title="Sil"><i class="ti ti-trash text-danger"></i></a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-secondary">Henüz kayıtlı kullanıcı yok.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
