@model Muhasebe.Models.Entities.Kullanici
@{
    ViewData["Title"] = "Kullanıcı Detayı";
    ViewData["PageTitle"] = $"{Model.Ad} {Model.Soyad}";
    ViewData["PageSubtitle"] = "Kullanıcı profil bilgileri.";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="row g-3">
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <span class="text-secondary small">E-posta</span>
                <p class="fw-semibold mb-0">@Model.Eposta</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <span class="text-secondary small">Departman</span>
                <p class="fw-semibold mb-0">@(Model.Departman?.DepartmanAdi ?? $"ID: {Model.DepartmanId}")</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <span class="text-secondary small">Rol</span>
                <p class="fw-semibold mb-0">@(Model.Rol?.RolAdi ?? $"ID: {Model.RolId}")</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <span class="text-secondary small">İşe Giriş</span>
                <p class="fw-semibold mb-0">@(Model.IseGirisTarihi?.ToString("dd.MM.yyyy") ?? "—")</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <span class="text-secondary small">Durum</span>
                <p class="mb-0">
                    @if (Model.Durum == true)
                    {
                        <span class="badge bg-success-subtle text-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger">Pasif</span>
                    }
                </p>
            </div>
        </div>
    </div>

    </div>

    @if (Model.Maas != null)
    {
        <h5 class="mt-4 mb-3">Maaş Bilgisi</h5>
        <div class="card border-0 shadow-sm p-4 mb-4">
            <p class="mb-1"><strong>Aylık Tutar:</strong> @Model.Maas.AylikTutar.ToString("C")</p>
            <p class="mb-0"><strong>Başlangıç Tarihi:</strong> @Model.Maas.BaslangicTarihi.ToString("dd.MM.yyyy")</p>
        </div>
    }

    <h5 class="mt-4 mb-3">Masraf Talepleri (@Model.MasrafTalebis.Count())</h5>
    <div class="card border-0 shadow-sm mb-4 table-responsive">
        <table class="table mb-0 text-nowrap align-middle table-hover">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Tarih</th>
                    <th>Tutar</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.MasrafTalebis != null && Model.MasrafTalebis.Any())
                {
                    foreach (var talep in Model.MasrafTalebis.OrderByDescending(m => m.TalepTarihi))
                    {
                        <tr>
                            <td>@talep.TalepId</td>
                            <td>@talep.TalepTarihi.ToString("dd.MM.yyyy")</td>
                            <td>@talep.Tutar.ToString("C")</td>
                            <td>
                                @if (talep.Durum == (int)Muhasebe.Common.Enums.DurumEnum.Bekliyor)
                                {
                                    <span class="badge bg-warning-subtle text-warning">Bekliyor</span>
                                }
                                else if (talep.Durum == (int)Muhasebe.Common.Enums.DurumEnum.Onaylandi)
                                {
                                    <span class="badge bg-success-subtle text-success">Onaylandı</span>
                                }
                                else if (talep.Durum == (int)Muhasebe.Common.Enums.DurumEnum.Reddedildi)
                                {
                                    <span class="badge bg-danger-subtle text-danger">Reddedildi</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">İptal Edildi</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-secondary">Personelin herhangi bir masraf talebi bulunmuyor.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.KullaniciId" class="btn btn-primary btn-sm"><i class="ti ti-edit"></i> Düzenle</a>
            <a asp-action="Delete" asp-route-id="@Model.KullaniciId" class="btn btn-outline-danger btn-sm"><i class="ti ti-trash"></i> Sil</a>
        </div>
    }
</div>
