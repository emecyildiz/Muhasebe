@model Muhasebe.Models.Entities.Kullanici
@{
    ViewData["Title"] = "Yeni Kullanıcı";
    ViewData["PageTitle"] = "Yeni Kullanıcı Kaydı";
    ViewData["PageSubtitle"] = "Yeni personel bilgilerini girin.";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="row">
        <div class="col-12 col-xl-10">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Ad" class="form-label"></label>
                                <input asp-for="Ad" class="form-control" />
                                <span asp-validation-for="Ad" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Soyad" class="form-label"></label>
                                <input asp-for="Soyad" class="form-control" />
                                <span asp-validation-for="Soyad" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Eposta" class="form-label"></label>
                                <input asp-for="Eposta" type="email" class="form-control" />
                                <span asp-validation-for="Eposta" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SifreHash" class="form-label">Şifre</label>
                                <input asp-for="SifreHash" type="password" class="form-control" />
                                <span asp-validation-for="SifreHash" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DepartmanId" class="form-label">Departman</label>
                                <select asp-for="DepartmanId" class="form-select" asp-items="ViewBag.DepartmanId">
                                    <option value="">— Seçiniz —</option>
                                </select>
                                <span asp-validation-for="DepartmanId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="RolId" class="form-label">Rol</label>
                                <select asp-for="RolId" class="form-select" asp-items="ViewBag.RolListesi">
                                    <option value="">— Seçiniz —</option>
                                </select>
                                <span asp-validation-for="RolId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="IseGirisTarihi" class="form-label">İşe Giriş Tarihi</label>
                                <input asp-for="IseGirisTarihi" type="date" class="form-control" />
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" asp-for="Durum" checked />
                                    <label class="form-check-label" asp-for="Durum">Hesap aktif</label>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                            <a asp-action="Index" class="btn btn-light">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
