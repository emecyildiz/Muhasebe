@model Muhasebe.Models.Entities.DepartmanButce
@{
    ViewData["Title"] = "Bütçe Sil";
    ViewData["PageTitle"] = "Bütçe Kaydını Sil";
    ViewData["PageSubtitle"] = "Bu işlem geri alınamaz.";
}
@await Html.PartialAsync("_PageHeader")

<div class="container-fluid pb-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6">
            <div class="card border-danger border-opacity-25 shadow-sm">
                <div class="card-header bg-danger-subtle text-danger fw-semibold">
                    <i class="ti ti-alert-triangle me-2"></i> Silme Onayı
                </div>
                <div class="card-body p-4 text-center">
                    <p class="mb-2"><strong>@(Model.Departman?.DepartmanAdi ?? $"Departman #{Model.DepartmanId}")</strong></p>
                    <p class="text-secondary mb-4">@Model.Yil @(Model.Ay.HasValue ? $"/ {Model.Ay}" : "") dönemi — @Model.AyrilanButce.ToString("N2") ₺</p>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="ButceId" />
                        <button type="submit" class="btn btn-danger">Evet, Sil</button>
                        <a asp-action="Index" class="btn btn-light ms-2">Vazgeç</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
